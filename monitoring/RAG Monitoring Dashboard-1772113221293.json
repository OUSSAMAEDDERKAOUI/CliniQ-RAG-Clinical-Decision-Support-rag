{
  "title": "CliniQ RAG - Observability (RAG + Containers + Infra)",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "RAG - Application Metrics",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "RPS Global (sans /metrics)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(request_count_total{endpoint!=\"/metrics\"}[1m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Latence p95 (s) (sans /metrics)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket{endpoint!=\"/metrics\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "gauge",
      "title": "Error Rate (%)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(error_count_total[5m])) / sum(rate(request_count_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "RPS par endpoint (sans /metrics)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 8, "y": 9, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(request_count_total{endpoint!=\"/metrics\"}[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },

    {
      "type": "row",
      "title": "Docker Containers (cAdvisor)",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU par container (cores) - rag_CliniQ_*",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"rag_CliniQ_.*\", image!=\"\"}[1m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cores" } }
    },
    {
      "type": "timeseries",
      "title": "RAM par container (MB) - rag_CliniQ_*",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{name=~\"rag_CliniQ_.*\", image!=\"\"}) / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "mbytes" } }
    },
    {
      "type": "gauge",
      "title": "RAM Ollama (GB)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=\"rag_CliniQ_ollama\", image!=\"\"} / 1024 / 1024 / 1024",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "gbytes", "min": 0 } }
    },
    {
      "type": "timeseries",
      "title": "CPU Ollama (cores)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 8, "y": 24, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"rag_CliniQ_ollama\", image!=\"\"}[1m])",
          "legendFormat": "ollama",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cores" } }
    },

    {
      "type": "row",
      "title": "Infrastructure (node-exporter)",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU utilisé (%) - Host/VM",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "type": "gauge",
      "title": "RAM utilisée (%) - Host/VM",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 31, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "RAM utilisée (GB) - Host/VM",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 18, "y": 31, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024 / 1024",
          "legendFormat": "used_gb",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "gbytes" } }
    },
    {
      "type": "timeseries",
      "title": "Disk usage (%) (fstype!=tmpfs)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 39, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{fstype!=\"tmpfs\",mountpoint!=\"/boot\"} / node_filesystem_size_bytes{fstype!=\"tmpfs\",mountpoint!=\"/boot\"}))",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "type": "timeseries",
      "title": "Network receive (MB/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 39, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (device) (rate(node_network_receive_bytes_total{device!=\"lo\"}[1m])) / 1024 / 1024",
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "MBs" } }
    }
  ]
}